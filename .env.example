# MinuteMind configuration

# LLM backend: ollama (default, local+free) | groq | gemini | openai
MINUTEMIND_BACKEND=ollama

# Ollama model id (default path requires no API key)
MINUTEMIND_MODEL=llama3.1:8b

# Where the persistent Chroma store lives
CHROMA_PATH=.chroma

# Only needed for non-default backends
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
