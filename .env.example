# MinuteMind configuration

# LLM backend: ollama (default, local+free) | gemini | openai
MINUTEMIND_BACKEND=ollama

# Ollama model id (default path requires no API key)
MINUTEMIND_MODEL=llama3.1:8b

# Where the persistent Chroma store lives
CHROMA_PATH=.chroma

# Only needed for non-default backends
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
